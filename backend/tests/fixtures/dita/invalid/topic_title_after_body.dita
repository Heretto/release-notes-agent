<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE topic PUBLIC "-//OASIS//DTD DITA Topic//EN" "topic.dtd">
<!-- INVALID: DTD requires <title> before <body>. Reversed order violates the
     content model: (title, titlealts?, shortdesc?, prolog?, body?, ...).
     Error: Element topic content does not follow the DTD,
            expecting (title, ...), got (body title) -->
<topic id="topic-title-last">
  <body>
    <p>Body appears before the title.</p>
  </body>
  <title>Title Comes Too Late</title>
</topic>
