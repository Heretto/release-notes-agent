<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE task PUBLIC "-//OASIS//DTD DITA Task//EN" "task.dtd">
<!-- INVALID: <cmd> is the required first element inside <step>.
     step content model: ((note|hazardstatement)*, cmd, ...)
     Providing only <info> without <cmd> violates the content model.
     Error: Element step content does not follow the DTD,
            expecting (..., cmd, ...), got (info) -->
<task id="task-no-cmd">
  <title>Task With Incomplete Step</title>
  <taskbody>
    <steps>
      <step>
        <info>This step has info but no cmd element.</info>
      </step>
    </steps>
  </taskbody>
</task>
