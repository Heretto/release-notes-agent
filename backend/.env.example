# Application
APP_ENV=development
APP_SECRET_KEY=your-secret-key-change-in-production
APP_DEBUG=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/release_notes_db
REDIS_URL=redis://:devpassword@localhost:6379/0

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for credentials) — minimum 16 characters, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-encryption-key-change-in-production

# Google AI Studio
GOOGLE_AI_API_KEY=your-google-ai-api-key
GOOGLE_AI_MODEL=gemini-2.5-pro

# Jira (defaults, can be overridden per-user)
JIRA_WEBHOOK_SECRET=your-webhook-secret

# Heretto
HERETTO_BASE_URL=https://api.heretto.com

# Cookies (set COOKIE_SECURE=true when serving over HTTPS)
COOKIE_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:4200