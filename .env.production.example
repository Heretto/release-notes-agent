# Production Environment Configuration
# Copy this file to .env.production and fill in your values

# Database Configuration
POSTGRES_USER=produser
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=release_notes_production

# Redis Configuration  
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# Application Secrets (generate with: openssl rand -hex 32)
APP_SECRET_KEY=GENERATE_NEW_SECRET_KEY
JWT_SECRET_KEY=GENERATE_NEW_JWT_KEY
ENCRYPTION_KEY=GENERATE_NEW_ENCRYPTION_KEY

# Google AI Studio
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Jira Configuration
JIRA_WEBHOOK_SECRET=your-jira-webhook-secret

# Heretto Configuration
HERETTO_BASE_URL=https://api.heretto.com

# CORS Configuration (your domain)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# API URL (for frontend build)
API_URL=https://your-domain.com/api

# SSL Email (for Let's Encrypt)
SSL_EMAIL=admin@your-domain.com

# Domain Names
DOMAIN_NAME=your-domain.com
WWW_DOMAIN_NAME=www.your-domain.com


######
# TESTING CREDENTIALS - these are not used in production, only for testing purposes

# Jira
TEST_JIRA_URL=https://your-domain.atlassian.net
TEST_JIRA_USERNAME=test-user
TEST_JIRA_API_TOKEN=your-jira-api-token

# Heretto
TEST_HERETTO_LOGIN_USER=your-heretto-login-email
TEST_HERETTO_LOGIN_TOKEN=your-heretto-login-token


# Claude 
TEST_CLAUDE_API_KEY=your-test-claude-api-key
TEST_CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
TEST_OPENAI_API_KEY=your-test-openai-api-key
TEST_OPENAI_MODEL=gpt-4o